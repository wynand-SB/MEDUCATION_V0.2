  "Data": [
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B1",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "A sore throat is an inflammation of the back of the throat and tonsils, mostly caused by a virus and gets better on its own.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Pellegrino et al., 2023"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B1",
      "Med_Class_ID": "",
      "Target_Variable": "Age_Child_4_12y",
      "Statement_Text": "Bacterial infections make up about 25% of these cases, compared to just 10% to 15% otherwise.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Pellegrino et al., 2023"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B2",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "Common breathing viruses enter the throat lining, causing the release of warning signals that bring extra blood and redness to the area.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Petat et al., 2025"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B3",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "The illness is short and gets better without antibiotics in 50% to 80% of cases.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Bo et al., 2022"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B3",
      "Med_Class_ID": "",
      "Target_Variable": "Age_Elderly_65_79y",
      "Statement_Text": "A lasting cough remains at day 7 in up to 50% of cases, showing a longer impact on daily life.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Petat et al., 2025"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_02_ETI",
      "Bullet_ID": "B1",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "The main causes are common viruses like rhinovirus, adenovirus, and coronaviruses.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Caldwell et al., 2024"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_02_ETI",
      "Bullet_ID": "B2",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "Crowded living spaces increase the spread of these viruses.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Pellegrino et al., 2023"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_02_ETI",
      "Bullet_ID": "B3",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "High local rates of rheumatic fever mean a closer medical watch is needed to catch bacterial cases.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Pellegrino et al., 2023"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_03_IMP",
      "Bullet_ID": "B1",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "Signs include a sudden sore throat, pain when swallowing, a cough, a runny nose, and sometimes a rough voice.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Liang et al., 2025"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_03_IMP",
      "Bullet_ID": "B1",
      "Med_Class_ID": "",
      "Target_Variable": "Age_Child_4_12y",
      "Statement_Text": "Stomach pain, nausea, and throwing up also happen in up to 30% of cases.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Caldwell et al., 2024"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_03_IMP",
      "Bullet_ID": "B2",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "This illness causes missed school and an average of 6.5 days of lost work per episode.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Farghal et al., 2018"
    },
    {
      "ICD10_ID": "J02.9",
      "Section_ID": "SEC_03_IMP",
      "Bullet_ID": "B3",
      "Med_Class_ID": "",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "The high level of discomfort makes it hard to focus and rest well during the day.",
      "Nuance_Transition": "",
      "Route_Icon": "",
      "Reference_Link": "Osiejewska et al., 2022"
    },
    {
