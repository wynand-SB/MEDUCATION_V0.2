      "Reference_Link": "Wang et al., 2021"
    },
    {
      "ICD10_ID": "J06.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B2",
      "Target_Variable": "Universal_Statement",
      "Med_Class_ID": "",
      "Route_Icon": "",
      "Statement_Text": "The virus enters the body and causes the lining of the breathing tubes to swell. This leads to widened blood vessels, extra fluid, a blocked nose, and an irritated throat.",
      "Nuance_Transition": "",
      "Reference_Link": "Aramă et al., 2023"
    },
    {
      "ICD10_ID": "J06.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B3",
      "Target_Variable": "Universal_Statement",
      "Med_Class_ID": "",
      "Route_Icon": "",
      "Statement_Text": "The illness is normally short and gets better on its own. It is mainly treated by resting and managing the symptoms.",
      "Nuance_Transition": "",
      "Reference_Link": "Pelzman & Tung, 2021"
    },
    {
