      "Med_Class_ID": "",
      "Route_Icon": "",
      "Nuance_Transition": ""
    },
    {
      "ICD10_ID": "J18.9",
      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B2",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "Germs enter the lungs and release toxins that damage cells. The immune system spots them and releases chemicals to fight back, which can cause harmful swelling.",
