      "Section_ID": "SEC_01_DEF",
      "Bullet_ID": "B3",
      "Target_Variable": "Universal_Statement",
      "Statement_Text": "Severe cases have a 25% risk of death within 30 days and up to a 50% risk within one year.",
      "Reference_Link": "Schuurman et al., 2022",
      "Med_Class_ID": "",
      "Route_Icon": "",
      "Nuance_Transition": ""
    },
    {
      "ICD10_ID": "J18.9",
      "Section_ID": "SEC_01_DEF",
